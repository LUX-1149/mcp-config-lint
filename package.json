{
  "name": "mcp-config-lint",
  "version": "0.1.0",
  "description": "Local-first linter for risky MCP configuration files.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "mcp-config-lint": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "SECURITY.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "privacy:check": "node scripts/privacy-check.mjs",
    "privacy:check:local": "node scripts/privacy-check.mjs --local",
    "hooks:install": "node scripts/install-git-hooks.mjs",
    "pack:dry-run": "npm pack --dry-run --json",
    "prepack": "npm run build && npm run test && npm run privacy:check"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "fast-glob": "^3.3.3",
    "jsonc-parser": "^3.3.1",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "typescript": "^5.8.3",
    "tsx": "^4.20.6",
    "vitest": "^4.1.7"
  }
}
